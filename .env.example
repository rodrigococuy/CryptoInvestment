APP_NAME=CryptoTracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Configuración necesaria para Docker (MySQL en lugar de SQLite)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Configuración necesaria para Docker (Redis en lugar de local)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuración para que el Mail funcione en el contenedor
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025

# API Keys (Públicas según tu requerimiento)
COINMARKETCAP_API_KEY=eb0f46645f834894a980ca86ce338c0a
CMC_API_KEY=eb0f46645f834894a980ca86ce338c0a

# Ajustes de usuario para evitar problemas de permisos en Linux/Docker
WWWUSER=1000
WWWGROUP=1000

# Lo demás puede quedarse tal cual lo tenías, Laravel lo gestiona
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database